{
  "name": "atari800_core",
  "version": "5.2.0-cardputer",
  "description": "atari800 emulator core (upstream vendored, C-only subset for ESP32-S3)",
  "license": "GPL-2.0",
  "build": {
    "srcFilter": ["+<*>"],
    "includeDir": "src",
    "flags": [
      "-I$PROJECT_INCLUDE_DIR",
      "-DSTEREO_SOUND=0",
      "-DCARDPUTER_ATARI800",
      "-Wno-implicit-function-declaration",
      "-Wno-unused-variable",
      "-Wno-unused-parameter"
    ]
  }
}
